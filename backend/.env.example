# Server Configuration
PORT=3001
JWT_SECRET=your_secure_jwt_secret_here

# Database Configuration (PostgreSQL)
DB_HOST=your_hostinger_db_host
DB_PORT=5432
DB_NAME=lucesa_db
DB_USER=your_db_user
DB_PASS=your_db_password
DB_SSL=false

# CT Online / CT CONNECT Configuration
CT_API_BASE=http://connect.ctonline.mx:3001
CT_FTP_HOST=216.70.82.104
CT_FTP_USER=your_ct_ftp_user
CT_FTP_PASS=your_ct_ftp_password
CT_EMAIL=your_ct_email
CT_CLIENTE=your_ct_client_id
CT_RFC=your_ct_rfc

# Payment Gateways
# Mercado Pago
MP_ACCESS_TOKEN=your_mp_access_token

# PayPal (Sandbox or Live)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Email Service
GMAIL_USER=your_gmail_address
GMAIL_APP_PASS=your_gmail_app_password
NOTIFY_EMAIL=notifications@yourdomain.com

# Features
MARKUP_PERCENT=1.10
CT_TIMEOUT_MS=15000
